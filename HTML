<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Helptism - Início</title>

  <link rel="stylesheet" href="style.css">
</head>

<body>

<div class="layout">

  <!-- SIDEBAR -->
  <aside class="sidebar">

    <h2 class="logo">Helptism</h2>

    <!-- usuário -->
    <div class="user">
      <div class="avatar">👤</div>
      <p>Usuário</p>
    </div>

    <!-- menu lateral -->
    <nav class="menu">
      <a href="#">🏠 Início</a>
      <a href="#">👤 Perfil</a>
      <a href="#">📓 Diário</a>
      <a href="#">😊 Emoções</a>
      <a href="#">⚙ Configurações</a>
    </nav>

    <!-- saída -->
    <button class="logout">🚪 Sair</button>

  </aside>

  <!-- CONTEÚDO PRINCIPAL -->
  <main class="main">

    <!-- HEADER -->
    <header class="header">

      <h1>Olá, usuário 👋</h1>

      <!-- pesquisa -->
      <input type="text" placeholder="Buscar no Helptism..." class="search">

      <!-- notificações -->
      <div class="notif">🔔 2</div>

    </header>

    <!-- RESUMO -->
    <section class="summary">
      <h3>Resumo do dia</h3>
      <p>Você tem atividades pendentes e lembretes importantes.</p>
    </section>

    <!-- CARDS PRINCIPAIS -->
    <section class="cards">

      <div class="card">📓 Diário</div>
      <div class="card">📅 Rotina</div>
      <div class="card">🎵 Músicas</div>
      <div class="card">😊 Emoções</div>
      <div class="card">💬 Interações</div>

    </section>

    <!-- AÇÕES RÁPIDAS -->
    <section class="actions">
      <button>➕ Adicionar</button>
      <button>✏ Editar</button>
      <button>👀 Ver mais</button>
    </section>

  </main>

</div>

<!-- FOOTER -->
<footer class="footer">
  <p>Contato: suporte@helptism.com</p>
  <p>Versão 1.0 • © 2026 Helptism</p>
</footer>

<script src="script.js"></script>
</body>
</html>
